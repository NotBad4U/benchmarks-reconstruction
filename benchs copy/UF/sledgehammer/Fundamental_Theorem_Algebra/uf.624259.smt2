(assert (forall ((?v0 S3)) (= (f3 (f4 f7 ?v0) f15) ?v0)))
(assert (forall ((?v0 S3) (?v1 S6) (?v2 S2) (?v3 S3)) (let ((?v_0 (f12 (f13 f14 ?v0) ?v1))) (= (f3 ?v_0 (f3 (f8 f11 ?v2) ?v3)) (f3 (f4 (f5 ?v1 ?v2) ?v3) (ite (= ?v3 f15) ?v0 (f3 ?v_0 ?v3)))))))
