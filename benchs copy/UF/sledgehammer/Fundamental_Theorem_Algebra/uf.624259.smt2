(assert (not (= f1 f2)))
(assert (forall ((?v0 S2) (?v1 S3) (?v2 S3)) (= (f3 (f4 (f5 f6 ?v0) ?v1) ?v2) (f3 (f4 f7 (f3 (f8 f9 f10) ?v2)) (f3 (f8 f11 ?v0) ?v2)))))
