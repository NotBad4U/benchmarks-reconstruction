(assert (not (= f1 f2)))
(assert (forall ((?v0 S2) (?v1 S2)) (= (= (f3 (f4 f5 ?v0) ?v1) f1) (= ?v0 ?v1))))
(assert (not (= (f6 f7 (f8 (f9 (f10 f11 f12 f13)) f7)) f1)))
