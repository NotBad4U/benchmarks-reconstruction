(declare-fun f4 (S4 S2) S3)
(declare-fun f5 () S4)
(declare-fun f6 (S5 S5) S1)
(declare-fun f7 () S5)
(declare-fun f8 (S6 S5) S5)
(declare-fun f9 (S7) S6)
(declare-fun f10 (S4 S8 S4) S7)
