(assert (= (f15 f7 (f8 (f9 (f10 f11 f12 f13)) f7)) f1))
(assert (forall ((?v0 S5)) (= (f6 ?v0 f7) f1)))
(assert (forall ((?v0 S4) (?v1 S8) (?v2 S4) (?v3 S4) (?v4 S8) (?v5 S4)) (= (= (f10 ?v0 ?v1 ?v2) (f10 ?v3 ?v4 ?v5)) (and (= ?v0 ?v3) (and (= ?v1 ?v4) (= ?v2 ?v5))))))
(assert (forall ((?v0 S5) (?v1 S5)) (=> (= (f6 ?v0 ?v1) f1) (= (f15 ?v0 ?v1) f1))))
(assert (forall ((?v0 S5) (?v1 S5) (?v2 S5)) (=> (= (f6 ?v0 ?v1) f1) (=> (= (f6 ?v2 ?v0) f1) (= (f6 ?v2 ?v1) f1)))))
